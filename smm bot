        send_message(cid2, "<b>Yangi qiymatni kiriting:</b>", reply_markup=boshqarish_kb)
        put_file("step/{}.step".format(cid2), "editNomi-{}-{}-{}".format(xiz, b, ich))
        return

def main():
    init_dirs()
    get_bot_username()
    print("Bot ishga tushdi... olg'a")
    offset = 0
    order_check_counter = 0
    while True:
        try:
            params = {"timeout": 30, "offset": offset}
            resp = requests.get(BASE_URL + "getUpdates", params=params, timeout=40)
            updates = resp.json().get("result", [])
            for update in updates:
                offset = update["update_id"] + 1
                try:
                    if "message" in update:
                        process_message(update)
                    elif "callback_query" in update:
                        process_callback(update)
                except Exception as e:
                    print("Update processing error:", e)
            order_check_counter += 1
            if order_check_counter >= 10:
                order_check_counter = 0
                try:
                    check_orders()
                except Exception as e:
                    print("check_orders error:", e)
        except Exception as e:
            print("Polling error:", e)
            time.sleep(5)

if __name__ == "__main__":
    main()
