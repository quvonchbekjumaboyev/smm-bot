def check_orders():
    sayt = get_file("admin/sayt.txt", "").strip()
    api = get_file("admin/api.txt", "").strip()
    valyuta = get_file("admin/valyuta.txt", "so'm")
    if not sayt or not api:
        return
    import glob as glob_mod
    order_files = glob_mod.glob("buyurtma/*/order.txt")
    for of in order_files:
        folder = of.replace("buyurtma/", "").replace("/order.txt", "")
        order_id = get_file(of, "").strip()
        ega = get_file("buyurtma/{}/egasi.txt".format(folder), "").strip()
        if not order_id or not ega:
            continue
        try:
            r = requests.get("{}?key={}&action=status&order={}".format(sayt, api, order_id), timeout=10)
            stat = r.json()
            status = stat.get("status", "")
            remains = stat.get("remains", 0)
            if status == "Completed":
                send_message(ega, "<b>✅ Sizning {} raqamli buyurtmangiz to'liq bajarildi.</b>".format(folder))
                delete_path("buyurtma/{}".format(folder))
            elif status in ("Canceled", "Partial"):
                miqdor = float(get_file("buyurtma/{}/miqdor.txt".format(folder), "0") or 0)
                soni = float(get_file("buyurtma/{}/soni.txt".format(folder), "0") or 1)
                umumiy = miqdor / soni if soni else 0
                plus = float(remains or 0) * umumiy
                cur_bal = float(get_file("pul/{}.txt".format(ega), "0") or 0)
                put_file("pul/{}.txt".format(ega), str(cur_bal + plus))
                send_message(ega, "<b>⚠️ Sizning {} raqamli buyurtmangiz bekor qilindi.\n\n💳 Hisobingizga {} {} qaytarildi</b>".format(folder, plus, valyuta))
                delete_path("buyurtma/{}".format(folder))
        except Exception as e:
            print("check_orders error:", e)

